*.iso

# Personalspace private mount (README zustava trackovane)
personalspace/*
!personalspace/README.md


# Doctor-managed Organization GEN3 mount checkouts
# The Launchpad root tracks the registry and organizations/README.md, not nested organization Git histories.
organizations/*
!organizations/README.md

# Local template mount checkouts required by first-client Doctor gates.
# Template source lives in separate template repositories; root tracks only registry/runbook references.
templates/TemplatesRozjedeme-ai/

# Conglomerate Dashboard GEN3 — separatni privatni repo mount (v1 spike)
dashboard/

# Organization-local private mounts
organizations/*/private/
organizations/*/archive/
organizations/*/workspace/private/
organizations/*/productionspace/private/
organizations/*/company/colleagues/*/private/
organizations/*/company/colleagues/*/archive/
organizations/*/company/colleagues/*/archiv/

# Lokální drafty — po curated history cutu 2026-07-16 jsou drafts/ jen
# lokální netrackovaná plocha; sdílené návrhy patří do privátního
# Rozjedeme-ai/HumanAndMachines (conglomerate-ops/drafts/).
drafts/

# Canonical local task worktrees and sidecars (decision 0049 / CAC-0065).
.worktrees/
