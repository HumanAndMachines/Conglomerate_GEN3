# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Dependencies and generated output
node_modules/
**/node_modules/
coverage/
dist/
build/
out/
.next/
.turbo/
.cache/
*.tsbuildinfo
.eslintcache

# Python caches
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.venv/

# Launchpad root local override (per-machine personalspace_owner, extra local mounts).
# Never tracked: it carries machine-specific data. Seed it by hand from the .example.
launchpad.gen3.local.json

# Env and secrets
.env
.env.*
!.env.example
*.pem
*-service-account*.json
firebase-admin*.json
serviceAccountKey.json

# Logs and reports
*.log
logs/
*.lcov
report.*.json
playwright-report/
test-results/

# Launchpad runtime
launchpad/.local/
launchpad/logs/
launchpad/runtime/
launchpad/app/v1/.local/
launchpad/app/v1/logs/
launchpad/app/v1/runtime/
launchpad/app/v1/target/

# Local-only delivery checkouts
ClientCompanies/
ClientCompanies/**
client-companies/
client-companies/**

# IDE local state
.idea/
.cursor/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

