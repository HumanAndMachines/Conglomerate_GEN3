{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://humanandmachines.local/schemas/worktree.schema.json",
  "title": "HumanAndMachine Worktree Sidecar",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "organization",
    "organization_path",
    "workspace",
    "module",
    "module_path",
    "repo_kind",
    "base_branch",
    "branch",
    "mission_control_plan_code",
    "mission_control_plan_path",
    "worktree_path",
    "created_at",
    "created_by",
    "status"
  ],
  "properties": {
    "schema_version": { "const": "companiesascode.worktree.v1" },
    "organization": { "type": "string", "minLength": 1 },
    "organization_path": { "type": "string", "minLength": 1 },
    "workspace": { "type": "string", "minLength": 1 },
    "module": { "type": "string", "minLength": 1 },
    "module_path": { "type": "string", "minLength": 1 },
    "repo_kind": {
      "type": "string",
      "enum": ["module", "organization_root", "root_repo", "productionspace"]
    },
    "base_branch": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "minLength": 1 },
    "mission_control_plan_code": { "type": "string", "pattern": "^[A-Z]+-[0-9]+" },
    "mission_control_plan_path": { "type": "string", "minLength": 1 },
    "worktree_path": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "created_by": { "type": "string", "minLength": 1 },
    "conversation_origin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "agent_label",
        "thread_id",
        "thread_locator_status",
        "local_only",
        "captured_at"
      ],
      "properties": {
        "surface": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "maxLength": 80
        },
        "agent_label": { "type": "string", "minLength": 1, "maxLength": 120 },
        "thread_id": { "type": ["string", "null"], "minLength": 1, "maxLength": 512 },
        "thread_locator_status": {
          "type": "string",
          "enum": ["captured", "unavailable", "not_applicable"]
        },
        "local_only": { "const": true },
        "captured_at": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "thread_locator_status": { "const": "captured" } }
          },
          "then": { "properties": { "thread_id": { "type": "string", "minLength": 1 } } },
          "else": { "properties": { "thread_id": { "type": "null" } } }
        }
      ]
    },
    "recovery_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "summary", "blocker", "next_action", "updated_at"],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "in_progress",
            "blocked",
            "paused",
            "ready_to_commit",
            "ready_to_push",
            "ready_for_pr",
            "ready_for_review",
            "completed"
          ]
        },
        "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "blocker": { "type": ["string", "null"], "minLength": 1, "maxLength": 1000 },
        "next_action": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "updated_at": { "type": "string", "minLength": 1 }
      }
    },
    "last_touched": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "draft",
        "published_branch",
        "pr_open",
        "merged_cleanup_needed",
        "stale",
        "orphan_missing_plan",
        "invalid"
      ]
    },
    "pr_url": { "type": ["string", "null"] },
    "notes": { "type": "string" }
  }
}
