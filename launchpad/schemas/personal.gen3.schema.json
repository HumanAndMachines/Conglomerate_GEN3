{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rozjedeme.ai/schemas/personal.gen3.schema.json",
  "title": "Personalspace GEN3 configuration",
  "type": "object",
  "required": [
    "schema_version",
    "personal_generation",
    "owner",
    "repository",
    "privacy",
    "modules_manifest_path",
    "workspace_path",
    "gbrain",
    "secrets"
  ],
  "properties": {
    "schema_version": {
      "const": "humanandmachines.personal.gen3.v1"
    },
    "personal_generation": {
      "const": "gen3",
      "description": "Kanonický klíč generace osobního prostoru. Repo i mount používají _GEN3 marker podle decision 0045/0051."
    },
    "owner": {
      "type": "object",
      "required": [
        "github_username",
        "display_name",
        "type"
      ],
      "properties": {
        "github_username": {
          "type": "string",
          "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "human",
            "ai-colleague"
          ]
        }
      },
      "additionalProperties": true
    },
    "buddy": {
      "type": "object",
      "required": [
        "slug",
        "gbrain_path",
        "path",
        "repository",
        "runtime",
        "hermes"
      ],
      "properties": {
        "slug": {
          "type": "string",
          "minLength": 1
        },
        "gbrain_path": {
          "const": "gbrain"
        },
        "path": {
          "const": "buddy",
          "description": "Volitelný Doctor-managed mount private Hermes Profile Distribution."
        },
        "repository": {
          "type": "object",
          "required": [
            "github_repo",
            "visibility",
            "mount_strategy"
          ],
          "properties": {
            "github_repo": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
            },
            "visibility": {
              "const": "private"
            },
            "mount_strategy": {
              "const": "doctor-managed-nested-repo"
            }
          },
          "additionalProperties": true
        },
        "runtime": {
          "type": "object",
          "required": [
            "github_repo",
            "deployment_target",
            "local_execution"
          ],
          "properties": {
            "github_repo": {
              "const": "HumanAndMachines/Buddy"
            },
            "deployment_target": {
              "const": "owner-dedicated-personalspace-vps",
              "description": "Buddy-enabled Personalspace smí aktivovat runtime pouze na dedikované per-owner VPS."
            },
            "local_execution": {
              "const": "forbidden",
              "description": "Lokální Conglomerate/Personalspace smí držet konfiguraci, ale nesmí spouštět Hermes/Buddy runtime ani poskytovat localhost fallback."
            }
          },
          "additionalProperties": true
        },
        "hermes": {
          "type": "object",
          "required": [
            "software_repo",
            "profile_format",
            "profile_path"
          ],
          "properties": {
            "software_repo": {
              "const": "NousResearch/hermes-agent"
            },
            "profile_format": {
              "const": "hermes-profile-distribution"
            },
            "profile_path": {
              "const": "buddy"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "repository": {
      "type": "object",
      "required": [
        "github_repo",
        "mount_path",
        "visibility",
        "mount_strategy"
      ],
      "properties": {
        "github_repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+_GEN3$"
        },
        "mount_path": {
          "type": "string",
          "pattern": "^personalspace/[A-Za-z0-9_.-]+_GEN3$"
        },
        "visibility": {
          "const": "private"
        },
        "mount_strategy": {
          "const": "doctor-managed-nested-repo"
        }
      },
      "additionalProperties": true
    },
    "privacy": {
      "type": "object",
      "required": [
        "default_share",
        "agent_boundary",
        "shared_outputs"
      ],
      "properties": {
        "default_share": {
          "const": "private"
        },
        "agent_boundary": {
          "const": "personal-context-only"
        },
        "shared_outputs": {
          "const": "metadata-only"
        }
      },
      "additionalProperties": true
    },
    "modules_manifest_path": {
      "const": "modules.manifest.json"
    },
    "workspace_path": {
      "const": "workspace"
    },
    "gbrain": {
      "type": "object",
      "required": [
        "path",
        "repository",
        "software",
        "default_shared",
        "human_editor",
        "agent_access"
      ],
      "properties": {
        "path": {
          "const": "gbrain"
        },
        "repository": {
          "type": "object",
          "required": [
            "github_repo",
            "visibility",
            "mount_strategy"
          ],
          "properties": {
            "github_repo": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
            },
            "visibility": {
              "const": "private"
            },
            "mount_strategy": {
              "const": "doctor-managed-nested-repo"
            }
          },
          "additionalProperties": true
        },
        "software": {
          "type": "object",
          "required": [
            "github_repo",
            "install_source"
          ],
          "properties": {
            "github_repo": {
              "const": "garrytan/gbrain"
            },
            "install_source": {
              "const": "github:garrytan/gbrain"
            }
          },
          "additionalProperties": true
        },
        "default_shared": {
          "const": false
        },
        "human_editor": {
          "enum": [
            "obsidian",
            "none"
          ]
        },
        "agent_access": {
          "const": "mcp-only"
        }
      },
      "additionalProperties": true
    },
    "secrets": {
      "type": "object",
      "required": [
        "path",
        "custody_pattern",
        "git"
      ],
      "properties": {
        "path": {
          "const": "secrets"
        },
        "custody_pattern": {
          "const": "personalspace/<owner>_GEN3/secrets/<provider>/<scope>/<purpose>"
        },
        "git": {
          "const": "ignored"
        }
      },
      "additionalProperties": true
    },
    "shared_spaces": {
      "type": "array",
      "description": "Metadata-only slots for personal spaces shared into this machine. Each nested repo still needs its own GitHub access."
    }
  },
  "additionalProperties": true
}
